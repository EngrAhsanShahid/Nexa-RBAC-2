# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=camera_rbac

# JWT
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend / CORS
FRONTEND_ORIGINS=http://localhost:3000

# Auth cookie
COOKIE_NAME=access_token
COOKIE_DOMAIN=localhost
COOKIE_PATH=/api/v1
COOKIE_SAMESITE=strict
COOKIE_SECURE=false
COOKIE_MAX_AGE=3600

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false
MINIO_BUCKET=cameras
MINIO_URL_EXPIRES_SECONDS=1800

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_TOKEN_TTL=3600

# Gmail SMTP / MFA
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465
GMAIL_FROM_EMAIL=
MFA_OTP_EXPIRES_SECONDS=300
MFA_OTP_LENGTH=6

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ALERTS_TOPIC=alerts
KAFKA_GROUP_ID=frontend_ws_2